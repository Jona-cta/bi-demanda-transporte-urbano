# ============================================================================
#  Configuracion del modulo de IA
#
#  COPIA ESTE ARCHIVO COMO  .env  Y COLOCA TU PROPIA API KEY.
#  El archivo .env NO se versiona (esta en .gitignore): cada persona usa la suya.
# ============================================================================

# API Key de Google Gemini. Se obtiene gratis en https://ai.google.dev
# (Get API key -> Create API key). No requiere tarjeta.
GEMINI_API_KEY=

# Modelo a utilizar.
# Se recomienda gemini-flash-latest: es un alias que siempre apunta al modelo
# flash vigente, por lo que no queda obsoleto ni depende de que un modelo
# concreto tenga cuota gratuita asignada en tu proyecto.
# Si tu clave devuelve error 429 con limite 0, ese modelo no tiene cuota libre
# en tu proyecto; el modulo intentara automaticamente con modelos alternativos.
GEMINI_MODELO=gemini-flash-latest

# ============================================================================
#  Acceso al modulo
#
#  La contrasena NO se guarda aqui: se guarda su hash bcrypt. Ni este archivo
#  ni el repositorio contienen la clave en claro.
#
#  Credenciales de demostracion ya configuradas:
#     usuario: gerente     contrasena: demo2026
#
#  Para cambiar la contrasena, genera un hash nuevo con:
#     php -r "echo password_hash('TU_CLAVE', PASSWORD_BCRYPT);"
#  y pega el resultado en APP_PASSWORD_HASH.
# ============================================================================
APP_USUARIO=gerente
APP_PASSWORD_HASH=$2y$10$slAHOGrT3BZkPyExmEOlyOOVsQdI9e37Oz1vxDAtgTa0pWFPFH.WS

# Muestra las credenciales en la pantalla de acceso (util para la evaluacion).
# En un despliegue real esto iria en 0.
MOSTRAR_CREDENCIALES_DEMO=1
CLAVE_DEMO=demo2026
